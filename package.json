{
  "name": "spinuptui",
  "version": "0.22.2",
  "description": "SpinupTUI — a terminal dashboard for browsing, monitoring, and managing your SpinupWP servers and sites.",
  "type": "module",
  "bin": {
    "spinuptui": "bin/spinuptui.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwender/spinupwp-tui.git"
  },
  "homepage": "https://github.com/mwender/spinupwp-tui#readme",
  "bugs": {
    "url": "https://github.com/mwender/spinupwp-tui/issues"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "start": "bun run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "link-global": "bun link",
    "unlink-global": "bun unlink",
    "build:binary": "bun build src/index.tsx --compile --outfile spinuptui"
  },
  "keywords": [
    "spinupwp",
    "tui",
    "terminal-ui",
    "opentui",
    "wordpress",
    "devops",
    "dashboard"
  ],
  "author": "Michael Wender",
  "license": "MIT",
  "dependencies": {
    "@opentui-ui/toast": "^0.0.5",
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "react": "^19.0.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
