{
  "name": "spinupwp-cli-dashboard",
  "version": "0.1.0",
  "description": "A cool terminal UI for browsing and monitoring your SpinupWP servers and sites.",
  "type": "module",
  "bin": {
    "spinup": "./src/index.tsx"
  },
  "scripts": {
